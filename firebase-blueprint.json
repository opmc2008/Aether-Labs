{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "Url to user's profile picture" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "When the user last logged in" }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "A saved project idea and its full blueprint",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique project ID" },
        "userId": { "type": "string", "description": "Owner's user ID" },
        "title": { "type": "string", "description": "Project title" },
        "description": { "type": "string", "description": "Project description" },
        "field": { "type": "string", "description": "Project category (e.g., Robotics, IoT)" },
        "difficulty": { "type": "string", "description": "Difficulty level" },
        "estimatedCost": { "type": "string", "description": "Estimated cost" },
        "blueprint": { 
          "type": "object", 
          "description": "The detailed project data generated by AI",
          "properties": {
            "plan": { "type": "string" },
            "code": { "type": "string" },
            "bom": { "type": "array", "items": { "type": "object" } },
            "research": { "type": "object" },
            "circuit": { "type": "object" },
            "components": { "type": "array", "items": { "type": "object" } },
            "modelDescription": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores individual user profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Stores user-created project ideas and their full technical data"
    }
  }
}
